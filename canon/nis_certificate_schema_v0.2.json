{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nis_certificate_schema_v0.2.json",
  "type": "object",
  "required": ["certificate_id", "timestamp_utc", "repro_hash", "engine_signature", "inputs", "run_trace", "outputs", "initial_conditions"],
  "properties": {
    "certificate_id": {"type": "string"},
    "timestamp_utc": {"type": "string"},
    "repro_hash": {"type": "string"},
    "initial_conditions": {
      "type": "object",
      "required": ["t0_years", "genesis_mode", "driver", "H_base2_t0", "M_X_t0", "H_t0", "tau_eff_t0", "transient_warning"],
      "properties": {
        "t0_years": {"type": "number"},
        "genesis_mode": {"type": "string"},
        "driver": {"type": "string"},
        "H_base2_t0": {"type": "number"},
        "M_X_t0": {"type": "number"},
        "H_t0": {"type": "number"},
        "tau_eff_t0": {"type": "number"},
        "transient_warning": {"type": "boolean"}
      }
    },
    "engine_signature": {
      "type": "object",
      "required": ["version", "canon_hash", "determinism_mode"],
      "properties": {
        "version": {"type": "string"},
        "canon_hash": {"type": "string"},
        "determinism_mode": {"type": "string"}
      }
    },
    "inputs": {
      "type": "object",
      "required": ["input_state_hash", "assumption_toggles", "run_config_hash"],
      "properties": {
        "input_state_hash": {"type": "string"},
        "run_config_hash": {"type": "string"},
        "assumption_toggles": {"type": "object"}
      }
    },
    "run_trace": {
      "type": "object",
      "required": ["operator_stack_keys", "operators_executed_ids", "steps_computed", "dt_years", "warnings"],
      "properties": {
        "operator_stack_keys": {"type": "array", "items": {"type": "string"}},
        "operators_executed_ids": {"type": "array", "items": {"type": "string"}},
        "steps_computed": {"type": "integer"},
        "dt_years": {"type": "number"},
        "integrator": {"type": "string"},
        "convergence_metric": {},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    },
    "outputs": {
      "type": "object",
      "required": ["observables_emitted", "output_digest"],
      "properties": {
        "observables_emitted": {"type": "array", "items": {"type": "string"}},
        "output_digest": {"type": "string"}
      }
    },
    "falsification_check": {}
  }
}
