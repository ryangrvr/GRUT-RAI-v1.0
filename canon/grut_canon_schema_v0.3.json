{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grut_canon_schema_v0.3.json",
  "type": "object",
  "required": [
    "meta",
    "unit_system",
    "constants",
    "primitives",
    "memory_kernel",
    "operator_stack",
    "core_equations",
    "numeric_policy",
    "assumptions_registry",
    "observables"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schema_version", "phase", "status", "canon_hash"],
      "properties": {
        "schema_version": {"type": "string"},
        "phase": {"type": "string"},
        "status": {"type": "string"},
        "canon_hash": {"type": "string"}
      }
    },
    "constants": {
      "type": "object",
      "required": ["by_id", "aliases"],
      "properties": {
        "by_id": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["id", "symbol", "value", "units", "description"],
            "properties": {
              "id": {"type": "string"},
              "symbol": {"type": "string"},
              "value": {"type": ["number", "string"]},
              "units": {"type": "string"},
              "status": {"type": "string"},
              "bounds": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {"type": "number"}
              },
              "description": {"type": "string"}
            }
          }
        },
        "aliases": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        }
      }
    },
    "operator_stack": {
      "type": "object",
      "required": ["execution_order", "definitions"],
      "properties": {
        "execution_order": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "definitions": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["id", "role", "parameters", "math"],
            "properties": {
              "id": {"type": "string"},
              "role": {"type": "string"},
              "parameters": {"type": "array", "items": {"type": "string"}},
              "math": {"type": "array", "items": {"type": "string"}},
              "bootstrap_only": {"type": "boolean"}
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
